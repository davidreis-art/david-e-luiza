<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>David ❤️ Luiza</title>

<style>
body {
    margin: 0;
    font-family: 'Georgia', cursive;
    background: black;
    overflow: hidden;
    color: white;
    text-align: center;
}

/* Fundo mágico */
body::before {
    content: "";
    position: fixed;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, #1a1a2e, #000);
    animation: brilho 4s infinite alternate;
    z-index: -1;
}

@keyframes brilho {
    from {opacity: 0.7;}
    to {opacity: 1;}
}

/* Nome */
h1 {
    font-size: 50px;
    margin-top: 40px;
    color: gold;
    text-shadow: 0 0 20px gold;
    animation: magia 2s infinite alternate;
}

@keyframes magia {
    from {text-shadow: 0 0 10px gold;}
    to {text-shadow: 0 0 30px gold;}
}

.texto {
    width: 70%;
    margin: auto;
    margin-top: 20px;
}

/* Fotos */
.fotos {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 30px;
}

.fotos img {
    width: 200px;
    height: 250px;
    border-radius: 15px;
    border: 2px solid gold;
    object-fit: cover;
}

/* Corações */
.heart {
    position: absolute;
    animation: cair 5s linear infinite;
}

@keyframes cair {
    from {transform: translateY(-100px);}
    to {transform: translateY(100vh);}
}
</style>
</head>

<body>

<h1>David ✨ Luiza</h1>

<div class="texto">
    <p>
        1 mês com você foi simplesmente incrível...
        cada momento é especial, cada sorriso seu vale tudo ❤️
    </p>
</div>

<audio controls autoplay loop>
    <source src="musica.mp3" type="audio/mpeg">
</audio>

<div class="fotos">
    <img src="foto1.jpg">
    <img src="foto2.jpg">
    <img src="foto3.jpg">
</div>

<script>
setInterval(() => {
    let heart = document.createElement("div");
    heart.innerHTML = "❤️";
    heart.className = "heart";
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.fontSize = (10 + Math.random() * 20) + "px";
    document.body.appendChild(heart);

    setTimeout(() => {
        heart.remove();
    }, 5000);
}, 300);
</script>

</body>
</html>
